#!/usr/bin/env bash
# kitty-session-snapshot
# Dumps the current Kitty state into a session file that the next Kitty
# startup will replay via `startup_session`. For tabs running Claude
# Code (`claude` or the `pai` wrapper), looks up the latest session ID
# for the tab's project so the chat resumes mid-conversation.
#
# Best-effort: writes scrollback per tab to ~/.config/chats/scrollback/
# Idempotent: safe to run from a launchd agent every 30s.
#
# Usage: kitty-session-snapshot [target-file]

set -euo pipefail

# Make sure brew binaries (kitty, jq, plus any others) are reachable when
# this script is invoked by launchd, which runs with a minimal PATH.
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SESSION_FILE="${1:-$HOME/.config/kitty/sessions/last.conf}"
SCROLLBACK_DIR="$HOME/.config/chats/scrollback"
mkdir -p "$(dirname "$SESSION_FILE")" "$SCROLLBACK_DIR"

# Bail silently if Kitty isn't running with remote control
if ! kitty @ ls >/dev/null 2>&1; then
  exit 0
fi

state_json=$(kitty @ ls 2>/dev/null) || exit 0

# Find the most-recent Claude Code session for a given working directory.
# Claude's project hash = cwd with '/' → '-' (e.g. ~/IdeaProjects/foo
# becomes -Users-abogdanov-IdeaProjects-foo).
find_latest_claude_session() {
  local cwd="$1"
  # Expand ~ if present
  cwd="${cwd/#\~/$HOME}"
  local hash
  hash="$(echo "$cwd" | sed 's|/|-|g')"
  local dir="$HOME/.claude/projects/${hash}"
  [[ -d "$dir" ]] || return 1
  local latest
  latest="$(ls -t "$dir"/*.jsonl 2>/dev/null | head -1 || true)"
  [[ -n "$latest" ]] || return 1
  basename "$latest" .jsonl
}

# Filename-safe version of a string
sanitize() {
  printf '%s' "$1" | tr -c 'a-zA-Z0-9._-' '_' | cut -c1-80
}

# Write atomically to a tmp file, then mv into place
TMP="$(mktemp -t kitty-session.XXXXXX)"
trap "rm -f '$TMP'" EXIT

{
  echo "# Auto-generated by kitty-session-snapshot at $(date '+%Y-%m-%dT%H:%M:%S%z')"
  echo "# Edits will be overwritten. Source: ~/.local/bin/kitty-session-snapshot"
  echo ""

  echo "$state_json" | jq -c '.[].tabs[]' | while read -r tab; do
    title=$(echo "$tab" | jq -r '.title // "shell"')
    window_id=$(echo "$tab" | jq -r '.windows[0].id // empty')
    cwd=$(echo "$tab"   | jq -r '.windows[0].cwd  // "~"')
    cmdline=$(echo "$tab" | jq -r '.windows[0].foreground_processes[0].cmdline // [] | join(" ")')

    echo "new_tab $title"
    echo "cd $cwd"

    # Restore command, by process detection
    if [[ "$cmdline" == *"bun run"*"pai.ts"* ]] || [[ "$cmdline" == *"PAI/Tools/pai.ts"* ]]; then
      # PAI wrapper — restarts claude in ~/.claude
      echo "launch pai"
    elif [[ "$cmdline" =~ (^|/| )claude([[:space:]]|$) ]]; then
      # Plain claude — try to resume the latest session for this project
      if session_id=$(find_latest_claude_session "$cwd"); then
        echo "launch claude --resume $session_id"
      else
        echo "launch claude"
      fi
    else
      # Plain shell or other process — open an empty shell in the cwd
      echo "launch"
    fi

    # Best-effort scrollback dump per tab (active window)
    if [[ -n "$window_id" ]]; then
      out="$SCROLLBACK_DIR/$(sanitize "${title}_${window_id}").log"
      kitty @ get-text --match "id:${window_id}" --extent=all > "$out" 2>/dev/null || true
    fi

    echo ""
  done
} > "$TMP"

mv "$TMP" "$SESSION_FILE"
